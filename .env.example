# Backend auth. Leave empty for local no-auth development.
APP_API_KEY=

# Hugging Face Inference Providers token.
# Create token with Inference Providers permission.
HF_TOKEN=hf_your_token_here
HF_BASE_URL=https://router.huggingface.co/v1

# Default HF chat-completion models. You can add provider policy suffixes like :fastest or :cheapest.
DEFAULT_TARGET_MODEL=Qwen/Qwen2.5-7B-Instruct:fastest
DEFAULT_ATTACKER_MODEL=Qwen/Qwen2.5-7B-Instruct:fastest
DEFAULT_JUDGE_MODEL=Qwen/Qwen2.5-7B-Instruct:fastest

# Runtime paths.
DATABASE_PATH=../data/llm_eval.sqlite
REPORTS_DIR=../data/reports
MAX_PARALLELISM=8
ALLOW_OFFLINE_FALLBACK=true

# Frontend. Only needed if APP_API_KEY is set.
VITE_APP_API_KEY=
VITE_API_BASE_URL=/api
